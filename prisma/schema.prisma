
datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String          @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  
  // NextAuth standard relations
  accounts      Account[]
  sessions      Session[]

  transactions  Transaction[]
  categories    Category[]
  friends       Friend[]
  budgets       Budget[]
  notifications Notification[]
  conversations AIConversation[]
  settings      Settings?
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id        String   @id @default(cuid())
  userId    String?  // null means default global category
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  type      String   // 'INCOME' | 'EXPENSE'
  icon      String?  // Lucide icon name
  color     String?  // Hex color code
  createdAt DateTime @default(now())

  @@unique([userId, name, type])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  BILL
  SUBSCRIPTION
  INVESTMENT
  SAVINGS
  LOAN
  DEBT
  SPLIT_BILL
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  merchant       String
  amount         Float
  date           DateTime        @default(now())
  category       String
  notes          String?
  tags           String[]
  createdAt      DateTime        @default(now())
  
  receiptId      String?         @unique
  receipt        Receipt?        @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  splitBillId    String?         @unique
  splitBill      SplitBill?      @relation(fields: [splitBillId], references: [id], onDelete: SetNull)
}

model Receipt {
  id           String       @id @default(cuid())
  url          String
  merchant     String?
  total        Float?
  items        Json?        // List of items parsed
  extractedAt  DateTime     @default(now())
  transaction  Transaction?
}

model SplitBill {
  id             String            @id @default(cuid())
  totalAmount    Float
  groupSize      Int
  payerName      String            // Who paid the bill
  userPaidFirst  Boolean           // Did the current user pay first?
  userShare      Float             // User's own expense portion
  receivables    Float             // Total friend's shares to be collected
  friendsShares  FriendShare[]
  transaction    Transaction?
}

model Friend {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  createdAt DateTime      @default(now())
  shares    FriendShare[]

  @@unique([userId, name])
}

model FriendShare {
  id          String    @id @default(cuid())
  splitBillId String
  splitBill   SplitBill @relation(fields: [splitBillId], references: [id], onDelete: Cascade)
  friendId    String
  friend      Friend    @relation(fields: [friendId], references: [id], onDelete: Cascade)
  shareAmount Float
  isPaid      Boolean   @default(false)
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category  String
  limit     Float
  spent     Float    @default(0)
  month     Int      // 1-12
  year      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category, month, year])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  content   String
  type      String   // 'BUDGET_EXCEEDED', 'SAVINGS_MILESTONE', 'BILL_REMINDER', 'SUMMARY'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AIConversation {
  id        String       @id @default(cuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String       @default("New Conversation")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  AIMessage[]
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String         // 'user' | 'assistant'
  content        String
  receiptUrl     String?        // Attached receipt image url
  extractedData  Json?          // Temp stored transaction details before confirmation
  status         String         @default("sent") // 'sent' | 'pending_confirmation' | 'saved' | 'cancelled'
  createdAt      DateTime       @default(now())
}

model Settings {
  id                String  @id @default(cuid())
  userId            String  @unique
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency          String  @default("IDR")
  theme             String  @default("dark")
  budgetAlerts      Boolean @default(true)
  billReminders     Boolean @default(true)
  weeklySummary     Boolean @default(true)
}
